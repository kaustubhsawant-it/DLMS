# dlms.toml — Dynamic Living Memory Substrate config
# All fields optional. `dlms init` writes detected defaults.

[workspace]
name = "myproject"
# Multi-repo workspaces: list each repo root. Submodules are auto-detected.
roots = ["."]
# Commit atoms back to git (recommended) — teammates `git pull` memory updates.
shared = true

[scan]
# Default: language heuristics from manifests. Override here if needed.
include = []
exclude = ["node_modules", "dist", "build", ".venv", "target", ".dart_tool"]
max_file_kb = 512
follow_symlinks = false

[ingesters]
# Adapters run in order. Comment out to skip.
enabled = ["readme", "manifest", "schema", "git", "symbols", "modules"]

# Per-adapter overrides
[ingesters.schema]
# Auto-detected if unset. Force here for ambiguous repos.
# dialects = ["supabase", "prisma", "django", "sqlalchemy", "openapi"]

[ingesters.symbols]
# tree-sitter by default. Set lsp=true only if you need cross-file resolution
# in dynamic languages (Python, Ruby, Dart). Costs setup time.
lsp = false
# Walk by recency (last 90 days of git activity), cap files.
max_files = 50000

[secrets]
mode = "block"   # block | warn | off
extra_patterns = []

[bootstrap]
# Time budget for first-time `dlms ingest`. Use 300+ for large repos.
budget_seconds = 60
# Bootstrap context ceiling for SessionStart digest.
token_ceiling = 4000

[retrieval]
# Per-turn injection budget for UserPromptSubmit hook.
turn_token_cap = 3000
# Local embedder. Hosted only justified if >10k queries/day.
embedder = "bge-small-en-v1.5"
# Cross-encoder rerank.
reranker = "ms-marco-MiniLM-L6"

[sync]
# How atoms are shared between teammates.
mode = "git-jsonl"   # git-jsonl | sqlite-commit | off
export_path = ".dlms/atoms.jsonl"

[handoff]
# Auto-generate handoff doc when context capacity exceeds threshold.
capacity_warn_pct = 80
capacity_halt_pct = 85
keep_handoffs_days = 30

[branches]
# OODAR + main+tags discipline. Block direct edits on these branches.
protected = ["main", "stable"]
